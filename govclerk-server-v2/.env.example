# AssemblyAI (https://app.assemblyai.com)
ASSEMBLYAI_API_KEY=your_assemblyai_key

# OpenAI
OPENAI_KEY=your_openai_key

# AWS S3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=govclerk-uploads

# PlanetScale MySQL
PLANETSCALE_DB_HOST=your_host
PLANETSCALE_DB_USERNAME=your_username
PLANETSCALE_DB_PASSWORD=your_password
PLANETSCALE_DB=your_database_name

# Auth secret (shared secret used by internal webhooks)
UPLOAD_COMPLETE_WEBHOOK_SECRET=your_webhook_secret

# Server
PORT=8000