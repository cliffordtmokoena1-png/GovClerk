# GovClerk — Root .env.example
#
# This is a combined reference for all environment variables used across the
# GovClerk monorepo. Each sub-package has its own .env.example with the full
# list of variables for that service. Copy and fill in the values for the
# sub-package(s) you are working on.
#
# Sub-package env files:
#   - Frontend (Next.js):   GovClerkMinutes/.env.example
#   - Node.js API Server:   govclerk-server-v2/.env.example
#
# The variables below cover the Rust and Python services which do not have
# their own dedicated .env.example files.

# ---------------------------------------------------------------------------
# Rust Backend Server (RunPod / Docker)
# ---------------------------------------------------------------------------
PORT=8000
PUBLIC_KEY=your-ssh-public-key-for-runpod
RUST_SERVER_URL=http://localhost:8000
UPLOAD_COMPLETE_WEBHOOK_SECRET=your-upload-webhook-secret

# ---------------------------------------------------------------------------
# Python ML Server (GovClerkMinutes-server)
# ---------------------------------------------------------------------------
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
HUMDINGER_KEY=your-service-bearer-token
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=af-south-1

# ---------------------------------------------------------------------------
# For the full list of frontend variables, see GovClerkMinutes/.env.example
# ---------------------------------------------------------------------------
