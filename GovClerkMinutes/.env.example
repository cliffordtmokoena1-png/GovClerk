# ============================================================
# GovClerk Minutes — Environment Variables Example
# Copy this file to .env.local and fill in the values.
# ============================================================

# ----- PayStack (Payment Processing) -----
# Server-side secret key — keep this private
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Client-side public key — safe to expose in the browser
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Subscription plan codes — create these in your PayStack dashboard under
# Products > Subscriptions.
# Monthly plans
PAYSTACK_PLAN_ESSENTIAL_MONTHLY=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_PROFESSIONAL_MONTHLY=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_ELITE_MONTHLY=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_PREMIUM_MONTHLY=PLN_xxxxxxxxxxxx
# Annual plans
PAYSTACK_PLAN_ESSENTIAL_ANNUAL=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_PROFESSIONAL_ANNUAL=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_ELITE_ANNUAL=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_PREMIUM_ANNUAL=PLN_xxxxxxxxxxxx
# Legacy plan codes (kept for backward compatibility with existing subscribers)
PAYSTACK_PLAN_ZA_BASIC=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_ZA_PRO=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_ZA_BASIC_ANNUAL=PLN_xxxxxxxxxxxx
PAYSTACK_PLAN_ZA_PRO_ANNUAL=PLN_xxxxxxxxxxxx
# Legacy AI-agent plan codes (kept for backward compatibility)
PAYSTACK_PLAN_ANNUAL=PLN_annual_govclerk
PAYSTACK_PLAN_MONTHLY=PLN_monthly_govclerk

# ----- Database (PlanetScale) -----
PLANETSCALE_DB=your-database-name
PLANETSCALE_DB_HOST=aws.connect.psdb.cloud
PLANETSCALE_DB_USERNAME=your-db-username
PLANETSCALE_DB_PASSWORD=your-db-password

# ----- Clerk (Authentication) -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_WH_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Test environment overrides
NEXT_PUBLIC_CLERK_TEST_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_TEST_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_TEST_WH_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ----- AWS -----
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=af-south-1
AWS_LAMBDA_EDITOR_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_LAMBDA_EDITOR_ACCESS_KEY_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_WHATSAPP_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_WHATSAPP_ACCESS_KEY_SECRET=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ----- AI / LLM -----
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
AI_AGENT_ENABLED=false

# ----- PostHog (Analytics) -----
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=12345

# ----- Slack -----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
WHATSAPP_SLACK_WEBHOOK_SECRET=your-webhook-secret

# ----- WhatsApp (Meta / WATI) -----
META_WHATSAPP_BUSINESS_API_KEY=your-meta-whatsapp-api-key
META_WHATSAPP_BUSINESS_WEBHOOK_SECRET=your-webhook-secret

# ----- Twilio (Audio/Video) -----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxx
TURN_DOMAIN=global.turn.twilio.com
TURN_SERVER_KEY=your-turn-server-key
TURN_TLS_PORT=443

# ----- Postmark (Transactional Email) -----
POSTMARK_SERVER_TOKEN=your-postmark-server-token

# ----- Transcription / AI Services -----
PYANNOTE_API_KEY=your-pyannote-api-key
RUNPOD_API_KEY=your-runpod-api-key
RUST_SERVER_URL=http://localhost:8080
UPLOAD_COMPLETE_WEBHOOK_SECRET=your-upload-webhook-secret

# ----- HubSpot / Instantly (CRM / Outreach) -----
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxx

# ----- hCaptcha -----
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# ----- Meta Pixel -----
META_CONVERSIONS_API_KEY=your-meta-conversions-api-key
NEXT_PUBLIC_FB_PIXEL_ID=1234567890

# ----- App Config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_ENV=development
NEXT_PUBLIC_USE_PROD_SERVER_IN_DEV=false

# ----- Web Push (VAPID) -----
# VAPID_PRIVATE_KEY_B=your-vapid-private-key

# ----- Misc -----
TEST_MODE=false
VERBOSE=false
